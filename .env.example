# MongoDB Connection
# Replace with your actual MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/clinic

# Optional: For production, use a proper connection string
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clinic?retryWrites=true&w=majority

# CORS - Allowed origin for production
# In development, leave empty or set to "*"
# In production, set to your frontend URL (e.g., https://clinic.yourdomain.com)
ALLOWED_ORIGIN=

# API Authentication
# Generate a secure random string for production (e.g., openssl rand -hex 32)
# Clients must include this key in the Authorization header: Authorization: Bearer <API_KEY>
API_KEY=your-secret-api-key-change-in-production
